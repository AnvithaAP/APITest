{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "API Test Tag Schema",
  "type": "object",
  "required": ["scope", "intent", "concern", "type", "module", "release"],
  "properties": {
    "scope": {"const": "api"},
    "intent": {"enum": ["functional", "performance", "security", "reliability"]},
    "concern": {
      "enum": [
        "contract", "data", "behavior", "error", "auth",
        "latency", "capacity", "scalability", "stability",
        "authn", "authz", "injection", "secrets", "transport",
        "resilience", "timeouts", "retry", "chaos", "recovery"
      ]
    },
    "type": {
      "enum": [
        "smoke", "sanity", "regression", "system",
        "load", "stress", "spike", "soak", "benchmark",
        "compliance", "resilience", "recovery", "failover"
      ]
    },
    "module": {"type": "string"},
    "release": {"type": "string", "pattern": "^R\\d{4}\\.\\d{2}-S\\d{1,2}$"}
  }
}
